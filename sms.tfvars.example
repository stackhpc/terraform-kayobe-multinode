# Example tfvars file for running on SMS in user projects.
# - See variables.tf for variable descriptions
# - Items commented out must be uncommented and changed
# - Rocky Linux 9 image for Epoxy

#prefix = "changeme"

ansible_control_vm_flavor = "general.v1.tiny"
ansible_control_vm_name   = "ansible-control"
ansible_control_disk_size = 100

seed_vm_flavor = "general.v1.tiny"
seed_disk_size = 100

multinode_flavor     = "general.v1.medium"
multinode_image      = "overcloud-rocky-9-2025.1-20260420T162634"
#multinode_keypair    = "changeme"
multinode_vm_network = "stackhpc-ipv4-geneve"
multinode_vm_subnet  = "stackhpc-ipv4-geneve-subnet"
compute_count    = "2"
controller_count = "3"
compute_disk_size = 100
controller_disk_size = 100

#ssh_public_key = "changeme"
ssh_user       = "cloud-user"

storage_count  = "3"
storage_flavor = "general.v1.small"
storage_disk_size = 100

deploy_wazuh = false
infra_vm_flavor = "general.v1.tiny"
infra_vm_disk_size = 100

volume_type = ""
